#: includes/class-comment-action-service.php:57
msgid "This comment action is not supported."
msgstr "지원하지 않는 댓글 작업입니다."

#: includes/class-comment-action-service.php:66
msgid "The comment could not be found."
msgstr "댓글을 찾을 수 없습니다."

#: includes/class-comment-action-service.php:76
msgid "You are not allowed to manage this comment."
msgstr "이 댓글을 관리할 권한이 없습니다."

#: includes/class-comment-action-service.php:113
msgid "WordPress could not update the comment."
msgstr "워드프레스에서 댓글을 변경하지 못했습니다."

#: includes/class-comment-action-service.php:151
msgid "Comment content cannot be empty."
msgstr "댓글 내용은 비워 둘 수 없습니다."

#: includes/class-frontend-controller.php:75
msgid "Permanently delete this comment? This cannot be undone."
msgstr "이 댓글을 영구 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."

#: includes/class-frontend-controller.php:78
msgid "The request failed. Please try again."
msgstr "요청에 실패했습니다. 다시 시도해 주세요."

#: includes/class-frontend-controller.php:80
msgid "Saving..."
msgstr "저장 중..."

#: includes/class-frontend-controller.php:81
msgid "Working..."
msgstr "처리 중..."

#: includes/class-frontend-controller.php:165
msgid "You must be logged in."
msgstr "로그인이 필요합니다."

#: includes/class-frontend-controller.php:172
msgid "The security token is invalid or has expired."
msgstr "보안 토큰이 유효하지 않거나 만료되었습니다."

#: includes/class-frontend-controller.php:201
msgid "Permanent deletion was not confirmed."
msgstr "영구 삭제가 확인되지 않았습니다."

#: includes/class-frontend-controller.php:307
msgid "Comment management actions"
msgstr "댓글 관리 작업"

#: includes/class-frontend-controller.php:309
msgid "Edit"
msgstr "수정"

#: includes/class-frontend-controller.php:311
msgid "Unapprove"
msgstr "비승인"

#: includes/class-frontend-controller.php:312
msgid "Mark as spam"
msgstr "스팸 처리"

#: includes/class-frontend-controller.php:313
msgid "Move to Trash"
msgstr "휴지통으로 이동"

#: includes/class-frontend-controller.php:314
msgid "Delete permanently"
msgstr "영구 삭제"

#: includes/class-frontend-controller.php:315
msgid "Comment content"
msgstr "댓글 내용"

#: includes/class-frontend-controller.php:316
msgid "Save"
msgstr "저장"

#: includes/class-frontend-controller.php:317
msgid "Cancel"
msgstr "취소"

